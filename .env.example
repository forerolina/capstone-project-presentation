# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# IANA timezone for appointment wall-clock times (booking, calendar, reschedule)
BUSINESS_TIMEZONE="America/Bogota"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Stripe (optional — only if you add paid checkout later)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_APPOINTMENT_PRICE_ID=""

# Resend (confirmation email)
RESEND_API_KEY=""
RESEND_FROM=""
# Optional copy in emails
BUSINESS_NAME=""
# Default service label on bookings and calendar (single service for now)
DEFAULT_SERVICE_NAME="Consultation"
# Optional “what to bring” / prep notes in booking confirmation (Sprint 1)
APPOINTMENT_PREP_NOTES=""
